# Fathom — environment configuration
# Copy to .env and fill in your values.

# ── LLM provider ───────────────────────────────────────────────────
# Which provider the api talks to. One of: gemini, openai, ollama.
# Defaults to gemini.
FATHOM_PROVIDER=gemini

# API key for your chosen provider.
#   gemini — https://aistudio.google.com/apikey
#   openai — https://platform.openai.com/api-keys
#   ollama — leave blank, runs locally
FATHOM_API_KEY=

# Optional overrides. Leave blank to use the provider defaults.
#   gemini → gemini-2.5-flash
#   openai → gpt-4o
#   ollama → llama3.1 @ http://localhost:11434/v1/
FATHOM_BASE_URL=
FATHOM_MODEL=

# ── Lake auth ──────────────────────────────────────────────────────
# Optional API key for delta-store. If set, all direct delta-store
# requests need an X-API-Key header. Leave blank for single-user setups.
DELTA_API_KEY=

# ── Postgres ───────────────────────────────────────────────────────
# Password for the postgres container. Change for anything beyond
# local single-user use.
POSTGRES_PASSWORD=fathom

# ── Misc ───────────────────────────────────────────────────────────
# Timezone (affects log timestamps).
TZ=UTC
