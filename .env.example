# Fathom — environment configuration
# Copy to .env and fill in your values.

# ── LLM provider ───────────────────────────────────────────────────
# Which provider the api talks to. One of: gemini, openai, ollama.
# Defaults to gemini.
LLM_PROVIDER=gemini

# API key for your chosen provider.
#   gemini — https://aistudio.google.com/apikey
#   openai — https://platform.openai.com/api-keys
#   ollama — leave blank, runs locally
# (Not to be confused with FATHOM_API_KEY, which is the bearer token
# Fathom's own client tools use to authenticate to this API.)
LLM_API_KEY=

# Optional overrides. Leave blank to use the provider defaults.
#   gemini → gemini-2.5-flash
#   openai → gpt-4o
#   ollama → llama3.1 @ http://localhost:11434/v1/
LLM_BASE_URL=
LLM_MODEL=

# ── Lake auth ──────────────────────────────────────────────────────
# Optional API key for delta-store. If set, all direct delta-store
# requests need an X-API-Key header. Leave blank for single-user setups.
DELTA_API_KEY=

# ── Postgres ───────────────────────────────────────────────────────
# Password for the postgres container. Change for anything beyond
# local single-user use.
POSTGRES_PASSWORD=fathom

# ── Instance + lake location ──────────────────────────────────────
# Everything about this install — container names, the postgres volume,
# and the lake state directory — derives from COMPOSE_PROJECT_NAME.
# Default "fathom" is fine for a single install. For a second instance
# on the same machine, clone into a second directory and change this
# (e.g. "fathom-dev") — containers, volume, and lake dir all re-namespace.
COMPOSE_PROJECT_NAME=fathom

# Where this instance's state lives on disk. Images, backups, drift/mood
# history, tokens — everything that's not the postgres database. Postgres
# itself lives in a named volume (${COMPOSE_PROJECT_NAME}-pg) because it
# can't run on Dropbox-synced paths.
# MUST be an absolute path — compose doesn't expand ~ or $HOME inside .env.
# Default for a single-user install: $HOME/.fathom/mind.
# preflight (./addons/scripts/preflight.sh) sets this correctly the first
# time you run it.
LAKE_DIR=/home/CHANGE-ME/.fathom/mind

# ── Misc ───────────────────────────────────────────────────────────
# Timezone (affects log timestamps).
TZ=UTC
