{
  "name": "fathomdx-devtools",
  "version": "0.0.0",
  "private": true,
  "description": "Dev-time tooling (eslint, prettier) for fathomdx addons. Not published.",
  "type": "module",
  "scripts": {
    "lint": "eslint 'addons/**/*.{js,mjs,cjs}'",
    "lint:fix": "eslint 'addons/**/*.{js,mjs,cjs}' --fix",
    "format": "prettier --write 'addons/**/*.{js,mjs,cjs,json,md}'",
    "format:check": "prettier --check 'addons/**/*.{js,mjs,cjs,json,md}'"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.0"
  }
}
